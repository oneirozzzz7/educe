#!/bin/sh
# DeepForge pre-commit hook - 安全检查
# 安装: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

echo "🔒 DeepForge 安全检查..."
python scripts/security_check.py

if [ $? -ne 0 ]; then
    echo ""
    echo "⛔ 提交被阻止：发现敏感信息"
    echo "   运行 'python scripts/security_check.py' 查看详情"
    exit 1
fi
